# IP Camera URL (DroidCam, IP Webcam, etc.) — use 0 for USB/Pi Camera
IP_CAMERA_URL=0

# Backend API endpoint
# Replace 127.0.0.1 with the actual IP of the machine running the backend if it's running on a different device.
BACKEND_EVENT_URL=http://127.0.0.1:8000/vision-events
SEND_EVENTS_TO_BACKEND=true

# Frame dimensions
FRAME_WIDTH=640
FRAME_HEIGHT=480

# Hand gesture settings
# Front camera / mirrored stream nedeniyle sağ-sol ters ise true kalsın.
HAND_INVERT_SWIPE=true

# One physical gesture should produce one clean UI event.
HAND_COOLDOWN_SECONDS=0.7
HAND_RELEASE_SECONDS=0.25
HAND_SWIPE_REARM_DX=0.10

# Gesture detection thresholds
HAND_PINCH_THRESHOLD=0.34
HAND_SWIPE_MIN_DX=0.22
HAND_SWIPE_MAX_DY=0.16
HAND_OPEN_PALM_HOLD_SECONDS=0.8

# MediaPipe Hands settings
HAND_MODEL_COMPLEXITY=0
HAND_MIN_DETECTION_CONFIDENCE=0.65
HAND_MIN_TRACKING_CONFIDENCE=0.65
